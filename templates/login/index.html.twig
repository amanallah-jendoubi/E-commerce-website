{% extends 'base.html.twig' %}

{% block title %}Login{% endblock %}

{% block main %}
    <main>
        <div class="sm:flex sm:justify-between">
            <div class="w-[60%] mx-auto p-2 sm:w-[50%] sm:mx-0 sm:flex sm:justify-center sm:items-center md:w-[50%]">
                <div class="md:w-[70%] lg:w-[50%]">
                    <h1 class="text-center font-semibold text-2xl">Login</h1>

                    {{ form_start(form) }}

                    <div class="flex flex-col mb-3">
                        {{ form_label(form.email, 'Email', {'label_attr': {'class': 'mb-1 font-medium'}}) }}
                        {{ form_widget(form.email, {'attr': {
                            'class': 'focus:outline-none ring-1 p-2 rounded-lg focus:bg-orange-50 text-sm ' ~
                            (form.email.vars.errors|length > 0 ? 'ring-red-500' : 'ring-orange-500')
                        }}) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div class="flex flex-col mb-3">
                        {{ form_label(form.password, 'Password', {'label_attr': {'class': 'mb-1 font-medium'}}) }}
                        {{ form_widget(form.password, {'attr': {
                            'class': 'focus:outline-none ring-1 p-2 rounded-lg focus:bg-orange-50 ' ~
                            (form.password.vars.errors|length > 0 ? 'ring-red-500' : 'ring-orange-500')
                        }}) }}
                        {{ form_errors(form.password) }}
                    </div>

                    {# Flash error for invalid credentials #}
                    {% for message in app.flashes('error') %}
                        <p class="text-red-600">{{ message }}</p>
                    {% endfor %}

                    <div class="flex justify-center items-center mt-10">
                        {{ form_widget(form.submit, {'attr': {
                            'class': 'bg-orange-500 hover:bg-orange-600 p-3 px-5 rounded-full text-sm text-white md:text-base'
                        }}) }}
                    </div>

                    {{ form_end(form) }}
                </div>
            </div>

            <div class="hidden sm:block bg-orange-200 rounded-l-lg w-[50%]">
                <img class="hidden sm:block" src="{{ asset('images/general/login.png') }}" alt="">
            </div>
        </div>
    </main>

{% endblock %}

{% block services %} {% endblock %}
